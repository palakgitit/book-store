<%- include('header') %>

    <div class="books-page">

        <h1 class="page-title">

            All Books

        </h1>

        <div class="top-links">

            <a href="/" class="nav-btn">

                Home

            </a>

            <a href="/add-book" class="nav-btn">

                Add Book

            </a>

        </div>

        <div class="books-list">

            <% books.forEach(book=> { %>

                <div class="book-item">

                    <img class="book-image" src="/uploads/<%= book.image %>" alt="<%= book.title %>">

                    <div class="book-details">

                        <h2>

                            <%= book.title %>

                        </h2>

                        <p>

                            <strong>Author:</strong>

                            <%= book.author %>

                        </p>

                        <p>

                            <strong>Category:</strong>

                            <%= book.category %>

                        </p>

                        <p>

                            <strong>Price:</strong>

                            ₹<%= book.price %>

                        </p>

                        <p>

                            <strong>Quantity:</strong>

                            <%= book.quantity %>

                        </p>

                        <p>

                            <strong>Description:</strong>

                            <%= book.description %>

                        </p>

                    </div>

                    <div class="book-actions">

                        <a href="/edit-book/<%= book._id %>" class="edit-btn">

                            Edit

                        </a>

                        <a href="/delete-book/<%= book._id %>" class="delete-btn" onclick="return confirmDelete()">

                            Delete

                        </a>

                    </div>

                </div>

                <% }) %>

        </div>

    </div>

    <%- include('footer') %>